{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Agent Dashboard",
  "version": "0.1.0",
  "identifier": "com.anothersava.ai-agent-dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Agent Dashboard",
        "width": 420,
        "height": 320,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "transparent": false,
        "visible": false,
        "backgroundColor": "#1c1c1e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
